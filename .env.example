# Postgres connection string (Neon, or local Docker Postgres for dev)
DATABASE_URL=postgresql://user:password@localhost:5432/mediflow

# Better Auth — generate with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google sign-in (optional in dev; email OTP works without it)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Milestone 3: payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Milestone 4: video
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Email (Resend). Unset = emails print to the server console (dev).
RESEND_API_KEY=
# Verified sender; defaults to onboarding@resend.dev for quick testing.
# EMAIL_FROM="MediFlow <noreply@yourdomain.com>"

# Secret a scheduler must present to trigger /api/cron/reminders
# (Authorization: Bearer <CRON_SECRET>). Unset = endpoint is open (dev only).
# CRON_SECRET=

# Error monitoring (optional; unset disables Sentry entirely)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# Logging (optional; defaults to "debug" in dev, "info" in production)
# LOG_LEVEL=
