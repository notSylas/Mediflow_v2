{
  "info": {
    "_postman_id": "40afc387-3e3c-49d0-9d95-mediflow-api",
    "name": "MediFlow v2 API",
    "description": "Postman collection for local MediFlow v2 API smoke testing. Use the `MediFlow v2 Local` environment and paste Better Auth browser cookies into `patientCookie` and `doctorCookie`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Open login page",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Use this to verify the local app is running. Login in the browser and paste the browser Cookie header into the environment variables."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login page responds', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Unauthenticated guard sample",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/patient/home",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "patient", "home"]
            },
            "description": "Expected 401 without a Cookie header."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('rejects missing auth', () => {",
                  "  pm.expect(pm.response.code).to.eql(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
