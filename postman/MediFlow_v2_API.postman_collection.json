        {
          "name": "Start payment / confirm mock payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "{{patientCookie}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}/payment",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "{{appointmentId}}", "payment"]
            },
            "description": "In local dev without Razorpay keys this confirms the appointment directly with provider=mock. With Razorpay keys it returns an orderId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('payment response ok', () => pm.expect(pm.response.code).to.eql(200));",
                  "const json = pm.response.json();",
                  "if (json.orderId) pm.environment.set('razorpayOrderId', json.orderId);",
                  "if (json.appointment && json.appointment.id) pm.environment.set('appointmentId', json.appointment.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Razorpay payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "{{patientCookie}}"
              },
