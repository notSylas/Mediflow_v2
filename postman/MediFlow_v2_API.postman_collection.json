              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('slots ok', () => pm.expect(pm.response.code).to.eql(200));",
                  "const json = pm.response.json();",
                  "if (json.slots && json.slots.length) {",
                  "  pm.environment.set('startsAt', json.slots[0]);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List appointments",
