                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startsAt\": \"{{startsAt}}\",\n  \"visitReason\": \"general-consultation\",\n  \"symptoms\": \"Fever for two days\",\n  \"consent\": true,\n  \"consentSource\": \"web\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/appointments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments"]
            },
            "description": "Uses `startsAt` saved by `Get available slots`. If you want to attach a report, upload one first and add `\"reportId\": \"{{reportId}}\"` to this JSON body."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('created or conflict', () => pm.expect(pm.response.code).to.be.oneOf([201, 409]));",
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.id) pm.environment.set('appointmentId', json.id);",
                  "}"
